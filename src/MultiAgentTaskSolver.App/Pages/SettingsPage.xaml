<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MultiAgentTaskSolver.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:MultiAgentTaskSolver.App.ViewModels"
    x:DataType="viewModels:SettingsViewModel"
    Title="Settings">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label AutomationId="SettingsHeadingLabel" Style="{StaticResource PageHeadingStyle}" Text="Workspace settings" />
            <Label Style="{StaticResource FormFieldHint}" Text="Configure the local workspace and the OpenAI gateway connection used by the app." />

            <Border Style="{StaticResource SurfaceCardStyle}" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Style="{StaticResource SectionHeadingStyle}" Text="Workspace and gateway" />

                    <VerticalStackLayout Spacing="2">
                        <Label Style="{StaticResource FormFieldTitle}" Text="Workspace root" />
                        <Label Style="{StaticResource FormFieldSubtitle}" Text="Base folder where task folders, manifests, run artifacts, and imported files are stored." />
                    </VerticalStackLayout>
                    <Entry
                        AutomationId="WorkspaceRootEntry"
                        Placeholder="Folder where task workspaces are stored."
                        Style="{StaticResource FormEntryStyle}"
                        Text="{Binding WorkspaceRootPath}" />
                    <Button
                        AutomationId="BrowseWorkspaceButton"
                        Command="{Binding BrowseWorkspaceFolderCommand}"
                        HorizontalOptions="Start"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Text="Browse Workspace Folder" />

                    <VerticalStackLayout Spacing="2">
                        <Label Style="{StaticResource FormFieldTitle}" Text="OpenAI gateway base URL" />
                        <Label Style="{StaticResource FormFieldSubtitle}" Text="Include the scheme (e.g. https://your-service-host). Do not add endpoint-specific paths." />
                    </VerticalStackLayout>
                    <Entry
                        AutomationId="OpenAiGatewayBaseUrlEntry"
                        Keyboard="Url"
                        Placeholder="https://your-gateway-host"
                        Style="{StaticResource FormEntryStyle}"
                        Text="{Binding OpenAiGatewayBaseUrl}" />

                    <VerticalStackLayout Spacing="2">
                        <Label Style="{StaticResource FormFieldTitle}" Text="OpenAI client bearer token" />
                        <Label Style="{StaticResource FormFieldSubtitle}" Text="Stored locally on this machine. Used for authenticated calls from the app to the gateway." />
                    </VerticalStackLayout>
                    <Entry
                        AutomationId="OpenAiBearerTokenEntry"
                        IsPassword="True"
                        Placeholder="Paste the client bearer token"
                        Style="{StaticResource FormEntryStyle}"
                        Text="{Binding OpenAiBearerToken}" />

                    <HorizontalStackLayout Spacing="12">
                        <Button
                            AutomationId="SaveSettingsButton"
                            Command="{Binding SaveCommand}"
                            HorizontalOptions="Start"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Text="Save Settings" />
                    </HorizontalStackLayout>
                    <Label AutomationId="SettingsErrorLabel" Style="{StaticResource ErrorLabelStyle}" Text="{Binding ErrorMessage}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <VerticalStackLayout Spacing="2">
                        <Label AutomationId="OpenAiModelsHeadingLabel" Style="{StaticResource SectionHeadingStyle}" Text="Seeded OpenAI models" />
                        <Label Style="{StaticResource FormFieldSubtitle}" Text="Models available through the gateway for review and worker selection. Informational only." />
                    </VerticalStackLayout>
                    <CollectionView AutomationId="OpenAiModelsCollectionView" ItemsSource="{Binding OpenAiModels}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:ModelEntryViewModel">
                                <Border Style="{StaticResource SurfaceCardStyle}" Padding="12" Margin="0,0,0,8">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Style="{StaticResource BodyStrongStyle}" Text="{Binding DisplayName}" />
                                        <Label Style="{StaticResource CaptionLabelStyle}" Text="{Binding ModelId}" />
                                        <Label Text="{Binding Description}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MultiAgentTaskSolver.App.Pages.TaskDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:MultiAgentTaskSolver.App.ViewModels"
    xmlns:pages="clr-namespace:MultiAgentTaskSolver.App.Pages"
    x:DataType="viewModels:TaskDetailsViewModel"
    Title="Task Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label Style="{StaticResource PageHeadingStyle}" Text="Task details" />
            <Label AutomationId="TaskRootPathLabel" Style="{StaticResource ItalicBodyStyle}" Text="{Binding TaskRootPath}" />
            <Label AutomationId="TaskStatusLabel" Style="{StaticResource StatusLabelStyle}" Text="{Binding TaskStatusText}" />
            <Label AutomationId="TaskUsageSummaryLabel" Style="{StaticResource FormFieldHint}" Text="{Binding TaskUsageSummaryText}" />

            <!-- Section 1: Task Definition (expanded by default) -->
            <pages:CollapsibleSection x:Name="TaskDefinitionSection" Title="Task Definition" StateKey="section.details.definition">
                <pages:CollapsibleSection.SectionBody>
                    <VerticalStackLayout Spacing="14">
                        <VerticalStackLayout Spacing="2">
                            <Label Style="{StaticResource FormFieldTitle}" Text="Task title" />
                            <Label Style="{StaticResource FormFieldSubtitle}" Text="Short, specific name. Describes the task clearly in the list view." />
                        </VerticalStackLayout>
                        <Entry AutomationId="TaskTitleEntry" Placeholder="e.g. Summarize Q4 sales transcripts" Style="{StaticResource FormEntryStyle}" Text="{Binding Title}" />

                        <VerticalStackLayout Spacing="2">
                            <Label Style="{StaticResource FormFieldTitle}" Text="Short summary" />
                            <Label Style="{StaticResource FormFieldSubtitle}" Text="Quick overview for scanning. Keep it compact so the current state of the task is easy to understand." />
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="0">
                            <Border Style="{StaticResource EditorPanelStyle}">
                                <Editor
                                    x:Name="TaskSummaryEditor"
                                    AutomationId="TaskSummaryEditor"
                                    AutoSize="Disabled"
                                    HeightRequest="96"
                                    Placeholder="Describe what the task should accomplish and why."
                                    Style="{StaticResource FormEditorStyle}"
                                    Text="{Binding Summary}" />
                            </Border>
                            <Border
                                x:Name="TaskSummaryResizeHandle"
                                AutomationId="TaskSummaryResizeHandle"
                                Style="{StaticResource EditorResizeHandleStyle}">
                                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                                    <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                                    <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                                    <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                                </HorizontalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Style="{StaticResource FormFieldTitle}" Text="Task instructions" />
                            <Label Style="{StaticResource FormFieldSubtitle}" Text="Full task definition. Explain the work, what inputs matter, what to ignore, and how outputs should be structured. Markdown recommended." />
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="0">
                            <Border Style="{StaticResource EditorPanelStyle}">
                                <Editor
                                    x:Name="TaskMarkdownEditor"
                                    AutomationId="TaskMarkdownEditor"
                                    AutoSize="Disabled"
                                    HeightRequest="300"
                                    Placeholder="Write the full task prompt. Use headings, bullet lists, and examples when useful."
                                    Style="{StaticResource FormEditorStyle}"
                                    Text="{Binding TaskMarkdown}" />
                            </Border>
                            <Border
                                x:Name="TaskMarkdownResizeHandle"
                                AutomationId="TaskMarkdownResizeHandle"
                                Style="{StaticResource EditorResizeHandleStyle}">
                                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                                    <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                                    <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                                    <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                                </HorizontalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <HorizontalStackLayout Spacing="12">
                            <Button AutomationId="TaskSaveButton" Style="{StaticResource PrimaryActionButtonStyle}" Text="Save" Command="{Binding SaveCommand}" />
                            <Button AutomationId="TaskRunHistoryButton" Style="{StaticResource SecondaryActionButtonStyle}" Text="Flow &amp; History" Command="{Binding OpenRunHistoryCommand}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </pages:CollapsibleSection.SectionBody>
            </pages:CollapsibleSection>

            <!-- Section 2: Inputs & Outputs (expanded by default) -->
            <pages:CollapsibleSection x:Name="InputsOutputsSection" Title="Inputs &amp; Outputs" StateKey="section.details.io">
                <pages:CollapsibleSection.SectionBody>
                    <VerticalStackLayout Spacing="14">
                        <VerticalStackLayout Spacing="2">
                            <Label AutomationId="TaskInputPathsHeadingLabel" Style="{StaticResource FormFieldTitle}" Text="Input folders" />
                            <Label Style="{StaticResource FormFieldSubtitle}" Text="Declared input folders. Import files into a folder, then copy the @alias to reference them in your task instructions." />
                        </VerticalStackLayout>

                        <VerticalStackLayout
                            AutomationId="InputFoldersCollectionView"
                            Spacing="8"
                            BindableLayout.ItemsSource="{Binding InputFolders}">
                            <BindableLayout.EmptyView>
                                <Label Text="No input folders declared. Add folders in the text editor below." />
                            </BindableLayout.EmptyView>
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:InputFolderViewModel">
                                    <Border Padding="10" Style="{StaticResource SurfaceCardStyle}">
                                        <VerticalStackLayout Spacing="6">
                                            <HorizontalStackLayout Spacing="8">
                                                <Label Style="{StaticResource BodyStrongStyle}" Text="{Binding Path}" />
                                                <Label Style="{StaticResource FormFieldHint}" Text="{Binding FileCount, StringFormat='{0} file(s)'}" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                            <VerticalStackLayout
                                                Spacing="4"
                                                BindableLayout.ItemsSource="{Binding Files}">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="viewModels:InputFileViewModel">
                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                            <VerticalStackLayout Spacing="2">
                                                                <Label Text="{Binding FileName}" />
                                                                <HorizontalStackLayout Spacing="8">
                                                                    <Label Style="{StaticResource FormFieldHint}" Text="{Binding Alias, StringFormat='@{0}'}" />
                                                                    <Label Style="{StaticResource FormFieldHint}" Text="{Binding SizeText}" />
                                                                </HorizontalStackLayout>
                                                            </VerticalStackLayout>
                                                        </Grid>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="0">
                            <Border Style="{StaticResource EditorPanelStyle}">
                                <Editor
                                    x:Name="TaskInputPathsEditor"
                                    AutomationId="TaskInputPathsEditor"
                                    AutoSize="Disabled"
                                    HeightRequest="120"
                                    Placeholder="e.g. inputs/research&#10;inputs/contracts"
                                    Style="{StaticResource FormEditorStyle}"
                                    Text="{Binding InputPathsText}" />
                            </Border>
                            <Border
                                x:Name="TaskInputPathsResizeHandle"
                                AutomationId="TaskInputPathsResizeHandle"
                                Style="{StaticResource EditorResizeHandleStyle}">
                                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                                    <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                                    <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                                    <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                                </HorizontalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label AutomationId="TaskOutputPathsHeadingLabel" Style="{StaticResource FormFieldTitle}" Text="Output files" />
                            <Label Style="{StaticResource FormFieldSubtitle}" Text="Stable deliverables under outputs/. Edit paths below. Leave blank to only keep run-scoped history copies." />
                        </VerticalStackLayout>

                        <VerticalStackLayout
                            AutomationId="OutputTargetsCollectionView"
                            Spacing="8"
                            BindableLayout.ItemsSource="{Binding OutputTargets}">
                            <BindableLayout.EmptyView>
                                <Label Text="No output targets declared yet." />
                            </BindableLayout.EmptyView>
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:OutputTargetViewModel">
                                    <Border Padding="10" Style="{StaticResource SurfaceCardStyle}">
                                        <VerticalStackLayout Spacing="4">
                                            <Label Style="{StaticResource BodyStrongStyle}" Text="{Binding Path}" />
                                            <Label Style="{StaticResource FormFieldHint}" Text="{Binding Description}" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="0">
                            <Border Style="{StaticResource EditorPanelStyle}">
                                <Editor
                                    x:Name="TaskOutputPathsEditor"
                                    AutomationId="TaskOutputPathsEditor"
                                    AutoSize="Disabled"
                                    HeightRequest="90"
                                    Placeholder="e.g. outputs/final-report.md"
                                    Style="{StaticResource FormEditorStyle}"
                                    Text="{Binding OutputPathsText}" />
                            </Border>
                            <Border
                                x:Name="TaskOutputPathsResizeHandle"
                                AutomationId="TaskOutputPathsResizeHandle"
                                Style="{StaticResource EditorResizeHandleStyle}">
                                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                                    <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                                    <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                                    <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                                </HorizontalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </pages:CollapsibleSection.SectionBody>
            </pages:CollapsibleSection>

            <!-- Section 3: Review Agent (collapsed by default) -->
            <pages:CollapsibleSection x:Name="ReviewAgentSection" Title="Review Agent" StateKey="section.details.review">
                <pages:CollapsibleSection.SectionBody>
                    <VerticalStackLayout Spacing="14">
                        <VerticalStackLayout Spacing="2">
                            <Label Style="{StaticResource FormFieldTitle}" Text="Review model" />
                            <Label Style="{StaticResource FormFieldSubtitle}" Text="Choose the model for the review step. Use a stronger model when the task is ambiguous or high risk." />
                        </VerticalStackLayout>
                        <Picker
                            AutomationId="TaskReviewModelPicker"
                            Style="{StaticResource FormPickerStyle}"
                            IsEnabled="{Binding CanRunTaskReview}"
                            ItemDisplayBinding="{Binding DisplayName}"
                            ItemsSource="{Binding ReviewModels}"
                            SelectedItem="{Binding SelectedReviewModel}" />
                        <Button
                            AutomationId="RunTaskReviewButton"
                            Command="{Binding RunTaskReviewCommand}"
                            IsEnabled="{Binding CanRunTaskReview}"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Text="Run Task Review" />

                        <Label AutomationId="LatestReviewHeadingLabel" Style="{StaticResource SubsectionHeadingStyle}" Text="Latest review summary" />
                        <Border Padding="10" Style="{StaticResource SurfaceCardStyle}">
                            <Label AutomationId="LatestReviewSummaryLabel" Text="{Binding LatestReviewSummary}" />
                        </Border>
                        <Label AutomationId="LatestReviewUsageLabel" Style="{StaticResource FormFieldHint}" Text="{Binding LatestReviewUsageText}" />

                        <Label AutomationId="LatestReviewOutputHeadingLabel" Style="{StaticResource SubsectionHeadingStyle}" Text="Latest review output" />
                        <Border Padding="10" Style="{StaticResource SurfaceCardStyle}">
                            <Editor
                                AutomationId="LatestReviewOutputEditor"
                                AutoSize="Disabled"
                                HeightRequest="200"
                                IsReadOnly="True"
                                Style="{StaticResource FormEditorStyle}"
                                Text="{Binding LatestReviewOutput}" />
                        </Border>

                        <Label
                            AutomationId="ReviewDecisionHeadingLabel"
                            IsVisible="{Binding CanApplyReviewDecision}"
                            Style="{StaticResource SubsectionHeadingStyle}"
                            Text="Review decision" />
                        <HorizontalStackLayout IsVisible="{Binding CanApplyReviewDecision}" Spacing="12">
                            <Button AutomationId="ApproveReviewButton" Style="{StaticResource PrimaryActionButtonStyle}" Text="Approve" Command="{Binding ApproveReviewCommand}" />
                            <Button AutomationId="ReviseReviewButton" Style="{StaticResource SecondaryActionButtonStyle}" Text="Revise Task" Command="{Binding ReviseReviewCommand}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </pages:CollapsibleSection.SectionBody>
            </pages:CollapsibleSection>

            <!-- Section 4: Worker Agent (collapsed by default) -->
            <pages:CollapsibleSection x:Name="WorkerAgentSection" Title="Worker Agent" StateKey="section.details.worker">
                <pages:CollapsibleSection.SectionBody>
                    <VerticalStackLayout Spacing="14">
                        <VerticalStackLayout Spacing="2">
                            <Label Style="{StaticResource FormFieldTitle}" Text="Worker model" />
                            <Label Style="{StaticResource FormFieldSubtitle}" Text="Choose the model that produces the actual output. Match to task complexity and cost tolerance." />
                        </VerticalStackLayout>
                        <Picker
                            AutomationId="WorkerModelPicker"
                            Style="{StaticResource FormPickerStyle}"
                            IsEnabled="{Binding CanRunWorker}"
                            ItemDisplayBinding="{Binding DisplayName}"
                            ItemsSource="{Binding WorkerModels}"
                            SelectedItem="{Binding SelectedWorkerModel}" />
                        <Button
                            AutomationId="RunWorkerButton"
                            Command="{Binding RunWorkerCommand}"
                            IsEnabled="{Binding CanRunWorker}"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Text="Run Worker" />

                        <Label AutomationId="LatestWorkerHeadingLabel" Style="{StaticResource SubsectionHeadingStyle}" Text="Latest worker summary" />
                        <Border Padding="10" Style="{StaticResource SurfaceCardStyle}">
                            <Label AutomationId="LatestWorkerSummaryLabel" Text="{Binding LatestWorkerSummary}" />
                        </Border>
                        <Label AutomationId="LatestWorkerUsageLabel" Style="{StaticResource FormFieldHint}" Text="{Binding LatestWorkerUsageText}" />

                        <Label AutomationId="LatestWorkerOutputHeadingLabel" Style="{StaticResource SubsectionHeadingStyle}" Text="Latest worker output" />
                        <Border Padding="10" Style="{StaticResource SurfaceCardStyle}">
                            <Editor
                                AutomationId="LatestWorkerOutputEditor"
                                AutoSize="Disabled"
                                HeightRequest="200"
                                IsReadOnly="True"
                                Style="{StaticResource FormEditorStyle}"
                                Text="{Binding LatestWorkerOutput}" />
                        </Border>
                    </VerticalStackLayout>
                </pages:CollapsibleSection.SectionBody>
            </pages:CollapsibleSection>

            <!-- Section 5: File Import (collapsed by default) -->
            <pages:CollapsibleSection x:Name="FileImportSection" Title="File Import" StateKey="section.details.import">
                <pages:CollapsibleSection.SectionBody>
                    <VerticalStackLayout Spacing="14">
                        <VerticalStackLayout Spacing="2">
                            <Label Style="{StaticResource FormFieldTitle}" Text="Import destination" />
                            <Label Style="{StaticResource FormFieldSubtitle}" Text="Choose which declared input folder should receive imported files. Imports are copied into the task workspace." />
                        </VerticalStackLayout>
                        <Picker AutomationId="ImportDestinationPicker" Style="{StaticResource FormPickerStyle}" ItemsSource="{Binding ImportDestinations}" SelectedItem="{Binding SelectedImportDestination}" />
                        <HorizontalStackLayout Spacing="12">
                            <Button AutomationId="ImportFilesButton" Style="{StaticResource SecondaryActionButtonStyle}" Text="Import Files" Command="{Binding ImportPickedFilesCommand}" />
                            <Button AutomationId="ImportFolderButton" Style="{StaticResource SecondaryActionButtonStyle}" Text="Import Folder" Command="{Binding ImportPickedFolderCommand}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </pages:CollapsibleSection.SectionBody>
            </pages:CollapsibleSection>

            <Label AutomationId="TaskDetailsErrorLabel" Style="{StaticResource ErrorLabelStyle}" Text="{Binding ErrorMessage}" />

            <!-- Section 6: Artifacts & Files (collapsed by default) -->
            <pages:CollapsibleSection x:Name="ArtifactsFilesSection" Title="Artifacts &amp; Files" StateKey="section.details.artifacts">
                <pages:CollapsibleSection.SectionBody>
                    <VerticalStackLayout Spacing="14">
                        <Label AutomationId="ArtifactsHeadingLabel" Style="{StaticResource SubsectionHeadingStyle}" Text="Artifacts" />
                        <VerticalStackLayout
                            AutomationId="ArtifactsCollectionView"
                            Spacing="8"
                            BindableLayout.ItemsSource="{Binding Artifacts}">
                            <BindableLayout.EmptyView>
                                <Label Text="No imported artifacts yet." />
                            </BindableLayout.EmptyView>
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:ArtifactEntryViewModel">
                                    <Border Padding="10" Style="{StaticResource SurfaceCardStyle}">
                                        <VerticalStackLayout Spacing="4">
                                            <Label Style="{StaticResource BodyStrongStyle}" Text="{Binding Alias}" />
                                            <Label Text="{Binding RelativePath}" />
                                            <Label Text="{Binding MediaType}" Style="{StaticResource FormFieldHint}" />
                                            <Label Text="{Binding SizeText}" Style="{StaticResource FormFieldHint}" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <Label AutomationId="FolderTreeHeadingLabel" Style="{StaticResource SubsectionHeadingStyle}" Text="Folder tree" />
                        <VerticalStackLayout
                            AutomationId="FolderTreeCollectionView"
                            Spacing="4"
                            BindableLayout.ItemsSource="{Binding TreeEntries}">
                            <BindableLayout.EmptyView>
                                <Label Text="No task files yet." />
                            </BindableLayout.EmptyView>
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:TaskTreeEntryViewModel">
                                    <Label Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </pages:CollapsibleSection.SectionBody>
            </pages:CollapsibleSection>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

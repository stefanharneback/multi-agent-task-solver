<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MultiAgentTaskSolver.App.Pages.TaskDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:MultiAgentTaskSolver.App.ViewModels"
    x:DataType="viewModels:TaskDetailsViewModel"
    Title="Task Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label Style="{StaticResource PageHeadingStyle}" Text="Task details" />
            <Label AutomationId="TaskRootPathLabel" Style="{StaticResource ItalicBodyStyle}" Text="{Binding TaskRootPath}" />
            <Label AutomationId="TaskStatusLabel" Style="{StaticResource StatusLabelStyle}" Text="{Binding TaskStatusText}" />
            <Label AutomationId="TaskUsageSummaryLabel" Style="{StaticResource FormFieldHint}" Text="{Binding TaskUsageSummaryText}" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Label Style="{StaticResource FormFieldTitle}" Text="Task title" />
                <Button CommandParameter="title" Clicked="OnHelpButtonClicked" Style="{StaticResource InfoButtonStyle}" Text="?" />
            </Grid>
            <Entry AutomationId="TaskTitleEntry" Placeholder="Short task name used in the task list and workspace." Style="{StaticResource FormEntryStyle}" Text="{Binding Title}" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Label Style="{StaticResource FormFieldTitle}" Text="Short summary" />
                <Button CommandParameter="summary" Clicked="OnHelpButtonClicked" Style="{StaticResource InfoButtonStyle}" Text="?" />
            </Grid>
            <VerticalStackLayout Spacing="0">
                <Border Style="{StaticResource EditorPanelStyle}">
                    <Editor
                        x:Name="TaskSummaryEditor"
                        AutomationId="TaskSummaryEditor"
                        AutoSize="Disabled"
                        HeightRequest="96"
                        Placeholder="Editable plain text. Describe the task briefly for the list and the next person reading it."
                        Style="{StaticResource FormEditorStyle}"
                        Text="{Binding Summary}" />
                </Border>
                <Border
                    x:Name="TaskSummaryResizeHandle"
                    AutomationId="TaskSummaryResizeHandle"
                    Style="{StaticResource EditorResizeHandleStyle}">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Label Style="{StaticResource FormFieldTitle}" Text="Task instructions" />
                <Button CommandParameter="instructions" Clicked="OnHelpButtonClicked" Style="{StaticResource InfoButtonStyle}" Text="?" />
            </Grid>
            <VerticalStackLayout Spacing="0">
                <Border Style="{StaticResource EditorPanelStyle}">
                    <Editor
                        x:Name="TaskMarkdownEditor"
                        AutomationId="TaskMarkdownEditor"
                        AutoSize="Disabled"
                        HeightRequest="300"
                        Placeholder="Editable plain text. Write the full task, constraints, references, and expected outputs."
                        Style="{StaticResource FormEditorStyle}"
                        Text="{Binding TaskMarkdown}" />
                </Border>
                <Border
                    x:Name="TaskMarkdownResizeHandle"
                    AutomationId="TaskMarkdownResizeHandle"
                    Style="{StaticResource EditorResizeHandleStyle}">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Label AutomationId="TaskInputPathsHeadingLabel" Style="{StaticResource FormFieldTitle}" Text="Input folders" />
                <Button CommandParameter="input-paths" Clicked="OnHelpButtonClicked" Style="{StaticResource InfoButtonStyle}" Text="?" />
            </Grid>
            <VerticalStackLayout Spacing="0">
                <Border Style="{StaticResource EditorPanelStyle}">
                    <Editor
                        x:Name="TaskInputPathsEditor"
                        AutomationId="TaskInputPathsEditor"
                        AutoSize="Disabled"
                        HeightRequest="120"
                        Placeholder="Editable plain text. One task-relative input folder per line."
                        Style="{StaticResource FormEditorStyle}"
                        Text="{Binding InputPathsText}" />
                </Border>
                <Border
                    x:Name="TaskInputPathsResizeHandle"
                    AutomationId="TaskInputPathsResizeHandle"
                    Style="{StaticResource EditorResizeHandleStyle}">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>
            <Label Style="{StaticResource FormFieldHint}" Text="You can edit these paths directly as plain text." />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Label AutomationId="TaskOutputPathsHeadingLabel" Style="{StaticResource FormFieldTitle}" Text="Output files" />
                <Button CommandParameter="output-paths" Clicked="OnHelpButtonClicked" Style="{StaticResource InfoButtonStyle}" Text="?" />
            </Grid>
            <VerticalStackLayout Spacing="0">
                <Border Style="{StaticResource EditorPanelStyle}">
                    <Editor
                        x:Name="TaskOutputPathsEditor"
                        AutomationId="TaskOutputPathsEditor"
                        AutoSize="Disabled"
                        HeightRequest="90"
                        Placeholder="Editable plain text. One task-relative output file per line."
                        Style="{StaticResource FormEditorStyle}"
                        Text="{Binding OutputPathsText}" />
                </Border>
                <Border
                    x:Name="TaskOutputPathsResizeHandle"
                    AutomationId="TaskOutputPathsResizeHandle"
                    Style="{StaticResource EditorResizeHandleStyle}">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>
            <Label Style="{StaticResource FormFieldHint}" Text="Each line should resolve under outputs/. Leave it blank if the run-scoped history copy is enough." />

            <HorizontalStackLayout Spacing="12">
                <Button AutomationId="TaskSaveButton" Style="{StaticResource PrimaryActionButtonStyle}" Text="Save" Command="{Binding SaveCommand}" />
                <Button AutomationId="TaskRunHistoryButton" Style="{StaticResource SecondaryActionButtonStyle}" Text="Flow &amp; History" Command="{Binding OpenRunHistoryCommand}" />
            </HorizontalStackLayout>

            <Label AutomationId="TaskReviewHeadingLabel" Style="{StaticResource SectionHeadingStyle}" Text="Task review agent" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Label Style="{StaticResource FormFieldTitle}" Text="Review model" />
                <Button CommandParameter="review-model" Clicked="OnHelpButtonClicked" Style="{StaticResource InfoButtonStyle}" Text="?" />
            </Grid>
            <Picker
                AutomationId="TaskReviewModelPicker"
                Style="{StaticResource FormPickerStyle}"
                IsEnabled="{Binding CanRunTaskReview}"
                ItemDisplayBinding="{Binding DisplayName}"
                ItemsSource="{Binding ReviewModels}"
                SelectedItem="{Binding SelectedReviewModel}" />
            <Button
                AutomationId="RunTaskReviewButton"
                Command="{Binding RunTaskReviewCommand}"
                IsEnabled="{Binding CanRunTaskReview}"
                Style="{StaticResource PrimaryActionButtonStyle}"
                Text="Run Task Review" />

            <Label AutomationId="LatestReviewHeadingLabel" Style="{StaticResource SectionHeadingStyle}" Text="Latest review summary" />
            <Border Padding="10" Style="{StaticResource SurfaceCardStyle}">
                <Label AutomationId="LatestReviewSummaryLabel" Text="{Binding LatestReviewSummary}" />
            </Border>
            <Label AutomationId="LatestReviewUsageLabel" Style="{StaticResource FormFieldHint}" Text="{Binding LatestReviewUsageText}" />

            <Label AutomationId="LatestReviewOutputHeadingLabel" Style="{StaticResource SectionHeadingStyle}" Text="Latest review output" />
            <Border Padding="10" Style="{StaticResource SurfaceCardStyle}">
                <Editor
                    AutomationId="LatestReviewOutputEditor"
                    AutoSize="Disabled"
                    HeightRequest="200"
                    IsReadOnly="True"
                    Style="{StaticResource FormEditorStyle}"
                    Text="{Binding LatestReviewOutput}" />
            </Border>

            <Label
                AutomationId="ReviewDecisionHeadingLabel"
                IsVisible="{Binding CanApplyReviewDecision}"
                Style="{StaticResource SectionHeadingStyle}"
                Text="Review decision" />
            <HorizontalStackLayout IsVisible="{Binding CanApplyReviewDecision}" Spacing="12">
                <Button AutomationId="ApproveReviewButton" Style="{StaticResource PrimaryActionButtonStyle}" Text="Approve" Command="{Binding ApproveReviewCommand}" />
                <Button AutomationId="ReviseReviewButton" Style="{StaticResource SecondaryActionButtonStyle}" Text="Revise Task" Command="{Binding ReviseReviewCommand}" />
            </HorizontalStackLayout>

            <Label AutomationId="WorkerHeadingLabel" Style="{StaticResource SectionHeadingStyle}" Text="Worker agent" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Label Style="{StaticResource FormFieldTitle}" Text="Worker model" />
                <Button CommandParameter="worker-model" Clicked="OnHelpButtonClicked" Style="{StaticResource InfoButtonStyle}" Text="?" />
            </Grid>
            <Picker
                AutomationId="WorkerModelPicker"
                Style="{StaticResource FormPickerStyle}"
                IsEnabled="{Binding CanRunWorker}"
                ItemDisplayBinding="{Binding DisplayName}"
                ItemsSource="{Binding WorkerModels}"
                SelectedItem="{Binding SelectedWorkerModel}" />
            <Button
                AutomationId="RunWorkerButton"
                Command="{Binding RunWorkerCommand}"
                IsEnabled="{Binding CanRunWorker}"
                Style="{StaticResource PrimaryActionButtonStyle}"
                Text="Run Worker" />

            <Label AutomationId="LatestWorkerHeadingLabel" Style="{StaticResource SectionHeadingStyle}" Text="Latest worker summary" />
            <Border Padding="10" Style="{StaticResource SurfaceCardStyle}">
                <Label AutomationId="LatestWorkerSummaryLabel" Text="{Binding LatestWorkerSummary}" />
            </Border>
            <Label AutomationId="LatestWorkerUsageLabel" Style="{StaticResource FormFieldHint}" Text="{Binding LatestWorkerUsageText}" />

            <Label AutomationId="LatestWorkerOutputHeadingLabel" Style="{StaticResource SectionHeadingStyle}" Text="Latest worker output" />
            <Border Padding="10" Style="{StaticResource SurfaceCardStyle}">
                <Editor
                    AutomationId="LatestWorkerOutputEditor"
                    AutoSize="Disabled"
                    HeightRequest="200"
                    IsReadOnly="True"
                    Style="{StaticResource FormEditorStyle}"
                    Text="{Binding LatestWorkerOutput}" />
            </Border>

            <Label AutomationId="ImportFilesHeadingLabel" Style="{StaticResource SectionHeadingStyle}" Text="Import files" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Label Style="{StaticResource FormFieldTitle}" Text="Import destination" />
                <Button CommandParameter="import-destination" Clicked="OnHelpButtonClicked" Style="{StaticResource InfoButtonStyle}" Text="?" />
            </Grid>
            <Picker AutomationId="ImportDestinationPicker" Style="{StaticResource FormPickerStyle}" ItemsSource="{Binding ImportDestinations}" SelectedItem="{Binding SelectedImportDestination}" />
            <HorizontalStackLayout Spacing="12">
                <Button AutomationId="ImportFilesButton" Style="{StaticResource SecondaryActionButtonStyle}" Text="Import Files" Command="{Binding ImportPickedFilesCommand}" />
                <Button AutomationId="ImportFolderButton" Style="{StaticResource SecondaryActionButtonStyle}" Text="Import Folder" Command="{Binding ImportPickedFolderCommand}" />
            </HorizontalStackLayout>

            <Label AutomationId="TaskDetailsErrorLabel" Style="{StaticResource ErrorLabelStyle}" Text="{Binding ErrorMessage}" />

            <Label AutomationId="ArtifactsHeadingLabel" Style="{StaticResource SectionHeadingStyle}" Text="Artifacts" />
            <VerticalStackLayout
                AutomationId="ArtifactsCollectionView"
                Spacing="8"
                BindableLayout.ItemsSource="{Binding Artifacts}">
                <BindableLayout.EmptyView>
                    <Label Text="No imported artifacts yet." />
                </BindableLayout.EmptyView>
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:ArtifactEntryViewModel">
                        <Border Padding="10" Style="{StaticResource SurfaceCardStyle}">
                            <VerticalStackLayout Spacing="4">
                                <Label Style="{StaticResource BodyStrongStyle}" Text="{Binding Alias}" />
                                <Label Text="{Binding RelativePath}" />
                                <Label Text="{Binding MediaType}" Style="{StaticResource FormFieldHint}" />
                                <Label Text="{Binding SizeText}" Style="{StaticResource FormFieldHint}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Label AutomationId="FolderTreeHeadingLabel" Style="{StaticResource SectionHeadingStyle}" Text="Folder tree" />
            <VerticalStackLayout
                AutomationId="FolderTreeCollectionView"
                Spacing="4"
                BindableLayout.ItemsSource="{Binding TreeEntries}">
                <BindableLayout.EmptyView>
                    <Label Text="No task files yet." />
                </BindableLayout.EmptyView>
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:TaskTreeEntryViewModel">
                        <Label Text="{Binding DisplayName}" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

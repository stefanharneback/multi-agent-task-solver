<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MultiAgentTaskSolver.App.Pages.TaskDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:MultiAgentTaskSolver.App.ViewModels"
    x:DataType="viewModels:TaskDetailsViewModel"
    Title="Task Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label AutomationId="TaskRootPathLabel" Text="{Binding TaskRootPath}" FontAttributes="Italic" />
            <Label AutomationId="TaskStatusLabel" Text="{Binding TaskStatusText}" FontAttributes="Bold" />

            <Entry AutomationId="TaskTitleEntry" Placeholder="Title" Text="{Binding Title}" />

            <Editor
                AutomationId="TaskSummaryEditor"
                AutoSize="TextChanges"
                HeightRequest="80"
                Placeholder="Summary"
                Text="{Binding Summary}" />

            <Editor
                AutomationId="TaskMarkdownEditor"
                AutoSize="TextChanges"
                HeightRequest="260"
                Text="{Binding TaskMarkdown}" />

            <HorizontalStackLayout Spacing="12">
                <Button AutomationId="TaskSaveButton" Text="Save" Command="{Binding SaveCommand}" />
                <Button AutomationId="TaskRunHistoryButton" Text="Flow &amp; History" Command="{Binding OpenRunHistoryCommand}" />
            </HorizontalStackLayout>

            <Label AutomationId="TaskReviewHeadingLabel" Text="Task review agent" FontAttributes="Bold" FontSize="18" />
            <Picker
                AutomationId="TaskReviewModelPicker"
                IsEnabled="{Binding CanRunTaskReview}"
                ItemDisplayBinding="{Binding DisplayName}"
                ItemsSource="{Binding ReviewModels}"
                SelectedItem="{Binding SelectedReviewModel}" />
            <Button
                AutomationId="RunTaskReviewButton"
                Command="{Binding RunTaskReviewCommand}"
                IsEnabled="{Binding CanRunTaskReview}"
                Text="Run Task Review" />

            <Label AutomationId="LatestReviewHeadingLabel" Text="Latest review summary" FontAttributes="Bold" FontSize="18" />
            <Border Padding="10" StrokeThickness="1">
                <Label AutomationId="LatestReviewSummaryLabel" Text="{Binding LatestReviewSummary}" />
            </Border>
            <Label AutomationId="LatestReviewUsageLabel" FontSize="12" Text="{Binding LatestReviewUsageText}" />

            <Label AutomationId="LatestReviewOutputHeadingLabel" Text="Latest review output" FontAttributes="Bold" FontSize="18" />
            <Border Padding="10" StrokeThickness="1">
                <Editor
                    AutomationId="LatestReviewOutputEditor"
                    AutoSize="TextChanges"
                    IsReadOnly="True"
                    Text="{Binding LatestReviewOutput}" />
            </Border>

            <Label
                AutomationId="ReviewDecisionHeadingLabel"
                FontAttributes="Bold"
                FontSize="18"
                IsVisible="{Binding CanApplyReviewDecision}"
                Text="Review decision" />
            <HorizontalStackLayout IsVisible="{Binding CanApplyReviewDecision}" Spacing="12">
                <Button AutomationId="ApproveReviewButton" Text="Approve" Command="{Binding ApproveReviewCommand}" />
                <Button AutomationId="ReviseReviewButton" Text="Revise Task" Command="{Binding ReviseReviewCommand}" />
            </HorizontalStackLayout>

            <Label AutomationId="WorkerHeadingLabel" Text="Worker agent" FontAttributes="Bold" FontSize="18" />
            <Picker
                AutomationId="WorkerModelPicker"
                IsEnabled="{Binding CanRunWorker}"
                ItemDisplayBinding="{Binding DisplayName}"
                ItemsSource="{Binding WorkerModels}"
                SelectedItem="{Binding SelectedWorkerModel}" />
            <Button
                AutomationId="RunWorkerButton"
                Command="{Binding RunWorkerCommand}"
                IsEnabled="{Binding CanRunWorker}"
                Text="Run Worker" />

            <Label AutomationId="LatestWorkerHeadingLabel" Text="Latest worker summary" FontAttributes="Bold" FontSize="18" />
            <Border Padding="10" StrokeThickness="1">
                <Label AutomationId="LatestWorkerSummaryLabel" Text="{Binding LatestWorkerSummary}" />
            </Border>
            <Label AutomationId="LatestWorkerUsageLabel" FontSize="12" Text="{Binding LatestWorkerUsageText}" />

            <Label AutomationId="LatestWorkerOutputHeadingLabel" Text="Latest worker output" FontAttributes="Bold" FontSize="18" />
            <Border Padding="10" StrokeThickness="1">
                <Editor
                    AutomationId="LatestWorkerOutputEditor"
                    AutoSize="TextChanges"
                    IsReadOnly="True"
                    Text="{Binding LatestWorkerOutput}" />
            </Border>

            <Label AutomationId="ImportFilesHeadingLabel" Text="Import files" FontAttributes="Bold" FontSize="18" />

            <Picker AutomationId="ImportDestinationPicker" ItemsSource="{Binding ImportDestinations}" SelectedItem="{Binding SelectedImportDestination}" />
            <Button AutomationId="ImportFilesButton" Text="Import Files" Command="{Binding ImportPickedFilesCommand}" />

            <Label AutomationId="TaskDetailsErrorLabel" Text="{Binding ErrorMessage}" TextColor="IndianRed" />

            <Label AutomationId="ArtifactsHeadingLabel" Text="Artifacts" FontAttributes="Bold" FontSize="18" />
            <CollectionView AutomationId="ArtifactsCollectionView" ItemsSource="{Binding Artifacts}">
                <CollectionView.EmptyView>
                    <Label Text="No imported artifacts yet." />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:ArtifactEntryViewModel">
                        <Border Padding="10" Margin="0,0,0,8" StrokeThickness="1">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Alias}" FontAttributes="Bold" />
                                <Label Text="{Binding RelativePath}" />
                                <Label Text="{Binding MediaType}" FontSize="12" />
                                <Label Text="{Binding SizeText}" FontSize="12" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label AutomationId="FolderTreeHeadingLabel" Text="Folder tree" FontAttributes="Bold" FontSize="18" />
            <CollectionView AutomationId="FolderTreeCollectionView" ItemsSource="{Binding TreeEntries}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:TaskTreeEntryViewModel">
                        <Label Text="{Binding DisplayName}" FontFamily="OpenSansRegular" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MultiAgentTaskSolver.App.Pages.TaskListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:MultiAgentTaskSolver.App.ViewModels"
    x:DataType="viewModels:TaskListViewModel"
    Title="Tasks">

    <Grid Padding="20" RowDefinitions="Auto,Auto,*" RowSpacing="16">
        <Label
            Text="Task workspace"
            FontAttributes="Bold"
            FontSize="24" />

        <Border Grid.Row="1" Padding="12" StrokeThickness="1">
            <VerticalStackLayout Spacing="10">
                <Label Text="{Binding WorkspaceRootPath}" FontAttributes="Italic" />
                <Button Text="Create Task" Clicked="OnCreateTaskClicked" HorizontalOptions="Start" />
                <Label Text="{Binding ErrorMessage}" TextColor="IndianRed" />
            </VerticalStackLayout>
        </Border>

        <CollectionView
            x:Name="TasksCollectionView"
            Grid.Row="2"
            ItemsSource="{Binding Tasks}"
            SelectionMode="Single"
            SelectionChanged="OnTaskSelectionChanged">
            <CollectionView.EmptyView>
                <Label Text="No tasks yet. Create the first task to initialize the workspace." />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:TaskListItemViewModel">
                    <Border Padding="12" Margin="0,0,0,10" StrokeThickness="1">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="18" />
                            <Label Text="{Binding Summary}" />
                            <Label Text="{Binding UpdatedAtText}" FontSize="12" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>

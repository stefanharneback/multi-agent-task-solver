<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MultiAgentTaskSolver.App.Pages.CreateTaskPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:MultiAgentTaskSolver.App.ViewModels"
    x:DataType="viewModels:CreateTaskViewModel"
    Title="Create Task">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label AutomationId="CreateTaskHeadingLabel" Text="New task" FontAttributes="Bold" FontSize="24" />

            <Entry AutomationId="CreateTaskTitleEntry" Placeholder="Title" Text="{Binding Title}" />

            <Editor
                AutomationId="CreateTaskSummaryEditor"
                AutoSize="Disabled"
                HeightRequest="80"
                Placeholder="Short summary"
                Text="{Binding Summary}" />

            <Entry
                AutomationId="CreateTaskCategoriesEntry"
                Placeholder="Additional input categories, comma separated"
                Text="{Binding AdditionalInputCategories}" />

            <Editor
                AutomationId="CreateTaskMarkdownEditor"
                AutoSize="Disabled"
                HeightRequest="320"
                Text="{Binding TaskMarkdown}" />

            <Label AutomationId="CreateTaskErrorLabel" Text="{Binding ErrorMessage}" TextColor="IndianRed" />

            <HorizontalStackLayout Spacing="12">
                <Button AutomationId="CreateTaskConfirmButton" Text="Create" Command="{Binding CreateCommand}" />
                <Button AutomationId="CreateTaskCancelButton" Text="Cancel" Command="{Binding CancelCommand}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

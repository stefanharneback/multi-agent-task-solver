<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MultiAgentTaskSolver.App.Pages.CreateTaskPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:MultiAgentTaskSolver.App.ViewModels"
    x:DataType="viewModels:CreateTaskViewModel"
    Title="Create Task">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label AutomationId="CreateTaskHeadingLabel" Style="{StaticResource PageHeadingStyle}" Text="New task" />
            <Label Style="{StaticResource FormFieldHint}" Text="Define the task, the folders it can use as input, and the files it should produce as output." />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Label Style="{StaticResource FormFieldTitle}" Text="Task title" />
                <Button CommandParameter="title" Clicked="OnHelpButtonClicked" Style="{StaticResource InfoButtonStyle}" Text="?" />
            </Grid>
            <Entry AutomationId="CreateTaskTitleEntry" Placeholder="Short task name used in the task list and workspace." Style="{StaticResource FormEntryStyle}" Text="{Binding Title}" />

            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                <Label Style="{StaticResource FormFieldTitle}" Text="Short summary" />
                <Button CommandParameter="summary" Clicked="OnHelpButtonClicked" Style="{StaticResource InfoButtonStyle}" Text="?" />
                <Button CommandParameter="summary:-1" Clicked="OnEditorHeightButtonClicked" Style="{StaticResource MiniButtonStyle}" Text="A-" />
                <Button CommandParameter="summary:1" Clicked="OnEditorHeightButtonClicked" Style="{StaticResource MiniButtonStyle}" Text="A+" />
            </Grid>
            <Editor
                x:Name="SummaryEditor"
                AutomationId="CreateTaskSummaryEditor"
                AutoSize="Disabled"
                HeightRequest="96"
                Placeholder="Editable plain text. Describe the goal, outcome, and important context in 1-4 short paragraphs."
                Style="{StaticResource FormEditorStyle}"
                Text="{Binding Summary}" />
            <Label Style="{StaticResource FormFieldHint}" Text="Plain text. Keep it short enough to scan quickly." />

            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                <Label AutomationId="CreateTaskInputPathsHeadingLabel" Style="{StaticResource FormFieldTitle}" Text="Input folders" />
                <Button CommandParameter="input-paths" Clicked="OnHelpButtonClicked" Style="{StaticResource InfoButtonStyle}" Text="?" />
                <Button CommandParameter="input-paths:-1" Clicked="OnEditorHeightButtonClicked" Style="{StaticResource MiniButtonStyle}" Text="A-" />
                <Button CommandParameter="input-paths:1" Clicked="OnEditorHeightButtonClicked" Style="{StaticResource MiniButtonStyle}" Text="A+" />
            </Grid>
            <Editor
                x:Name="InputPathsEditor"
                AutomationId="CreateTaskInputPathsEditor"
                AutoSize="Disabled"
                HeightRequest="120"
                Placeholder="Editable plain text. One task-relative folder per line, for example: research/articles"
                Style="{StaticResource FormEditorStyle}"
                Text="{Binding InputPathsText}" />
            <Label Style="{StaticResource FormFieldHint}" Text="You can type directly here or use Browse Input Folder to add a folder name." />
            <Button
                AutomationId="CreateTaskAddInputFolderButton"
                Command="{Binding AddInputFolderCommand}"
                Style="{StaticResource SecondaryActionButtonStyle}"
                Text="Browse Input Folder" />

            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                <Label AutomationId="CreateTaskOutputPathsHeadingLabel" Style="{StaticResource FormFieldTitle}" Text="Output files" />
                <Button CommandParameter="output-paths" Clicked="OnHelpButtonClicked" Style="{StaticResource InfoButtonStyle}" Text="?" />
                <Button CommandParameter="output-paths:-1" Clicked="OnEditorHeightButtonClicked" Style="{StaticResource MiniButtonStyle}" Text="A-" />
                <Button CommandParameter="output-paths:1" Clicked="OnEditorHeightButtonClicked" Style="{StaticResource MiniButtonStyle}" Text="A+" />
            </Grid>
            <Editor
                x:Name="OutputPathsEditor"
                AutomationId="CreateTaskOutputPathsEditor"
                AutoSize="Disabled"
                HeightRequest="90"
                Placeholder="Editable plain text. One task-relative output file per line, for example: deliverables/final-report.md"
                Style="{StaticResource FormEditorStyle}"
                Text="{Binding OutputPathsText}" />
            <Label Style="{StaticResource FormFieldHint}" Text="Each line should point to a file under outputs/." />
            <Button
                AutomationId="CreateTaskAddOutputFolderButton"
                Command="{Binding AddOutputFolderCommand}"
                Style="{StaticResource SecondaryActionButtonStyle}"
                Text="Browse Output Folder" />

            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                <Label Style="{StaticResource FormFieldTitle}" Text="Task instructions" />
                <Button CommandParameter="instructions" Clicked="OnHelpButtonClicked" Style="{StaticResource InfoButtonStyle}" Text="?" />
                <Button CommandParameter="instructions:-1" Clicked="OnEditorHeightButtonClicked" Style="{StaticResource MiniButtonStyle}" Text="A-" />
                <Button CommandParameter="instructions:1" Clicked="OnEditorHeightButtonClicked" Style="{StaticResource MiniButtonStyle}" Text="A+" />
            </Grid>
            <Editor
                x:Name="TaskMarkdownEditor"
                AutomationId="CreateTaskMarkdownEditor"
                AutoSize="Disabled"
                HeightRequest="320"
                Placeholder="Editable plain text. Write the full task, acceptance criteria, output expectations, and how inputs should be used."
                Style="{StaticResource FormEditorStyle}"
                Text="{Binding TaskMarkdown}" />
            <Label Style="{StaticResource FormFieldHint}" Text="Markdown is recommended for structure. Use headings, bullet lists, and examples when useful." />

            <Label AutomationId="CreateTaskErrorLabel" Text="{Binding ErrorMessage}" TextColor="IndianRed" />

            <HorizontalStackLayout Spacing="12">
                <Button AutomationId="CreateTaskConfirmButton" Style="{StaticResource PrimaryActionButtonStyle}" Text="Create" Command="{Binding CreateCommand}" />
                <Button AutomationId="CreateTaskCancelButton" Style="{StaticResource SecondaryActionButtonStyle}" Text="Cancel" Command="{Binding CancelCommand}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MultiAgentTaskSolver.App.Pages.CreateTaskPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:MultiAgentTaskSolver.App.ViewModels"
    x:DataType="viewModels:CreateTaskViewModel"
    Title="Create Task">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label AutomationId="CreateTaskHeadingLabel" Style="{StaticResource PageHeadingStyle}" Text="New task" />
            <Label Style="{StaticResource FormFieldHint}" Text="Define the task, declare any task-local input folders, and optionally declare explicit output file targets." />

            <VerticalStackLayout Spacing="2">
                <Label Style="{StaticResource FormFieldTitle}" Text="Task title" />
                <Label Style="{StaticResource FormFieldSubtitle}" Text="Short, specific name (3–10 words). Visible in the task list without opening the task." />
            </VerticalStackLayout>
            <Entry AutomationId="CreateTaskTitleEntry" Placeholder="e.g. Summarize Q4 sales transcripts" Style="{StaticResource FormEntryStyle}" Text="{Binding Title}" />

            <VerticalStackLayout Spacing="2">
                <Label Style="{StaticResource FormFieldTitle}" Text="Short summary" />
                <Label Style="{StaticResource FormFieldSubtitle}" Text="Compact overview of the goal, main constraints, and expected result. One to four short paragraphs." />
            </VerticalStackLayout>
            <VerticalStackLayout Spacing="0">
                <Border Style="{StaticResource EditorPanelStyle}">
                    <Editor
                        x:Name="SummaryEditor"
                        AutomationId="CreateTaskSummaryEditor"
                        AutoSize="Disabled"
                        HeightRequest="96"
                        Placeholder="Describe what the task should accomplish and why."
                        Style="{StaticResource FormEditorStyle}"
                        Text="{Binding Summary}" />
                </Border>
                <Border
                    x:Name="SummaryResizeHandle"
                    AutomationId="CreateTaskSummaryResizeHandle"
                    Style="{StaticResource EditorResizeHandleStyle}">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="2">
                <Label AutomationId="CreateTaskInputPathsHeadingLabel" Style="{StaticResource FormFieldTitle}" Text="Input folders" />
                <Label Style="{StaticResource FormFieldSubtitle}" Text="Task-local folders under inputs/. One folder per line. Use Browse to pick a folder name from your file system." />
            </VerticalStackLayout>
            <VerticalStackLayout Spacing="0">
                <Border Style="{StaticResource EditorPanelStyle}">
                    <Editor
                        x:Name="InputPathsEditor"
                        AutomationId="CreateTaskInputPathsEditor"
                        AutoSize="Disabled"
                        HeightRequest="120"
                        Placeholder="e.g. inputs/research&#10;inputs/contracts"
                        Style="{StaticResource FormEditorStyle}"
                        Text="{Binding InputPathsText}" />
                </Border>
                <Border
                    x:Name="InputPathsResizeHandle"
                    AutomationId="CreateTaskInputPathsResizeHandle"
                    Style="{StaticResource EditorResizeHandleStyle}">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>
            <Button
                AutomationId="CreateTaskAddInputFolderButton"
                Command="{Binding AddInputFolderCommand}"
                Style="{StaticResource SecondaryActionButtonStyle}"
                Text="Browse Input Folder" />

            <VerticalStackLayout Spacing="2">
                <Label AutomationId="CreateTaskOutputPathsHeadingLabel" Style="{StaticResource FormFieldTitle}" Text="Output files" />
                <Label Style="{StaticResource FormFieldSubtitle}" Text="Stable deliverables under outputs/. One file per line. Leave blank to only keep run-scoped history copies." />
            </VerticalStackLayout>
            <VerticalStackLayout Spacing="0">
                <Border Style="{StaticResource EditorPanelStyle}">
                    <Editor
                        x:Name="OutputPathsEditor"
                        AutomationId="CreateTaskOutputPathsEditor"
                        AutoSize="Disabled"
                        HeightRequest="90"
                        Placeholder="e.g. outputs/final-report.md"
                        Style="{StaticResource FormEditorStyle}"
                        Text="{Binding OutputPathsText}" />
                </Border>
                <Border
                    x:Name="OutputPathsResizeHandle"
                    AutomationId="CreateTaskOutputPathsResizeHandle"
                    Style="{StaticResource EditorResizeHandleStyle}">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="2">
                <Label Style="{StaticResource FormFieldTitle}" Text="Task instructions" />
                <Label Style="{StaticResource FormFieldSubtitle}" Text="Full task definition. Describe the work, how inputs should be used, acceptance criteria, and expected output format. Markdown recommended." />
            </VerticalStackLayout>
            <VerticalStackLayout Spacing="0">
                <Border Style="{StaticResource EditorPanelStyle}">
                    <Editor
                        x:Name="TaskMarkdownEditor"
                        AutomationId="CreateTaskMarkdownEditor"
                        AutoSize="Disabled"
                        HeightRequest="320"
                        Placeholder="Write the full task prompt. Use headings, bullet lists, and examples when useful."
                        Style="{StaticResource FormEditorStyle}"
                        Text="{Binding TaskMarkdown}" />
                </Border>
                <Border
                    x:Name="TaskMarkdownResizeHandle"
                    AutomationId="CreateTaskMarkdownResizeHandle"
                    Style="{StaticResource EditorResizeHandleStyle}">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                        <BoxView Style="{StaticResource EditorResizeGripStyle}" />
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>

            <Label AutomationId="CreateTaskErrorLabel" Style="{StaticResource ErrorLabelStyle}" Text="{Binding ErrorMessage}" />

            <HorizontalStackLayout Spacing="12">
                <Button AutomationId="CreateTaskConfirmButton" Style="{StaticResource PrimaryActionButtonStyle}" Text="Create" Command="{Binding CreateCommand}" />
                <Button AutomationId="CreateTaskCancelButton" Style="{StaticResource SecondaryActionButtonStyle}" Text="Cancel" Command="{Binding CancelCommand}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

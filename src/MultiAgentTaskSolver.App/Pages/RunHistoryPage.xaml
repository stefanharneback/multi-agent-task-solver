<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MultiAgentTaskSolver.App.Pages.RunHistoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:MultiAgentTaskSolver.App.ViewModels"
    x:DataType="viewModels:RunHistoryViewModel"
    Title="Flow &amp; History">

    <CollectionView
        AutomationId="RunHistoryCollectionView"
        ItemsSource="{Binding Runs}"
        SelectionMode="None">
        <CollectionView.Header>
            <VerticalStackLayout Padding="20" Spacing="18">
            <Label AutomationId="RunHistoryTaskTitleLabel" Style="{StaticResource PageHeadingStyle}" Text="{Binding TaskTitle}" />
            <Label AutomationId="RunHistoryTaskStatusLabel" Style="{StaticResource StatusLabelStyle}" Text="{Binding TaskStatusText}" />
            <Label AutomationId="RunHistoryNarrativeLabel" Text="{Binding ProgressNarrative}" />
            <Label AutomationId="RunHistoryErrorLabel" Style="{StaticResource ErrorLabelStyle}" Text="{Binding ErrorMessage}" />

            <Label AutomationId="RunHistorySummaryHeadingLabel" Style="{StaticResource SectionHeadingStyle}" Text="Progress snapshot" />
            <FlexLayout
                AutomationId="RunHistorySummaryMetrics"
                Direction="Row"
                Wrap="Wrap"
                BindableLayout.ItemsSource="{Binding SummaryMetrics}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:FlowSummaryMetricViewModel">
                        <Border Padding="12" Margin="0,0,12,12" MinimumWidthRequest="180">
                            <VerticalStackLayout Spacing="4">
                                <Label Style="{StaticResource CaptionLabelStyle}" Text="{Binding Label}" />
                                <Label Style="{StaticResource MetricValueStyle}" Text="{Binding Value}" />
                                <Label Style="{StaticResource CaptionLabelStyle}" Text="{Binding Detail}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>

            <Label AutomationId="RunHistoryFlowHeadingLabel" Style="{StaticResource SectionHeadingStyle}" Text="Task flow" />
            <ScrollView Orientation="Horizontal">
                <HorizontalStackLayout
                    AutomationId="RunHistoryFlowStages"
                    Spacing="12"
                    BindableLayout.ItemsSource="{Binding FlowStages}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:TaskFlowStageViewModel">
                            <Border Padding="12" WidthRequest="230">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsCurrent}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource StageCurrentBackground}" />
                                        <Setter Property="Stroke" Value="{StaticResource Primary}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsCompleted}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource StageCompletedBackground}" />
                                    </DataTrigger>
                                </Border.Triggers>

                                <VerticalStackLayout Spacing="6">
                                    <Label Style="{StaticResource BodyStrongStyle}" Text="{Binding Title}" />
                                    <Label Style="{StaticResource CaptionLabelStyle}" Text="{Binding StateText}" />
                                    <Label Style="{StaticResource CaptionLabelStyle}" Text="{Binding Detail}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>

            <Label AutomationId="RunHistoryTimelineHeadingLabel" Style="{StaticResource SectionHeadingStyle}" Text="Run timeline" />
            </VerticalStackLayout>
        </CollectionView.Header>

        <CollectionView.EmptyView>
            <Label Margin="20,0,20,20" Text="No runs yet." />
        </CollectionView.EmptyView>

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="viewModels:RunHistoryEntryViewModel">
                <Border Margin="20,0,20,14" Padding="12">
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="8">
                            <Label Style="{StaticResource BodyStrongStyle}" Text="{Binding SequenceText}" />
                            <Label Text="{Binding Status}" />
                        </HorizontalStackLayout>

                        <Label Style="{StaticResource CardTitleStyle}" Text="{Binding Title}" />
                        <Label Style="{StaticResource CaptionLabelStyle}" Text="{Binding KindText}" />
                        <Label Style="{StaticResource CaptionLabelStyle}" Text="{Binding TimingText}" />
                        <Label Style="{StaticResource CaptionLabelStyle}" Text="{Binding DurationText}" />
                        <Label Style="{StaticResource CaptionLabelStyle}" Text="{Binding ModelText}" />
                        <Label Style="{StaticResource CaptionLabelStyle}" Text="{Binding ReferencedAliasesText}" />
                        <Label Style="{StaticResource CaptionLabelStyle}" Text="{Binding StepCountText}" />
                        <Label Text="{Binding Summary}" />

                        <Label Style="{StaticResource SubsectionHeadingStyle}" Text="Steps" />
                        <VerticalStackLayout Spacing="10" BindableLayout.ItemsSource="{Binding Steps}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:StepHistoryEntryViewModel">
                                    <Border Padding="10" Margin="12,0,0,0">
                                        <VerticalStackLayout Spacing="4">
                                            <HorizontalStackLayout Spacing="8">
                                                <Label Style="{StaticResource BodyStrongStyle}" Text="{Binding SequenceText}" />
                                                <Label Text="{Binding Status}" />
                                            </HorizontalStackLayout>
                                            <Label Style="{StaticResource BodyStrongStyle}" Text="{Binding Title}" />
                                            <Label Style="{StaticResource CaptionLabelStyle}" Text="{Binding ModelText}" />
                                            <Label Style="{StaticResource CaptionLabelStyle}" Text="{Binding ProviderText}" />
                                            <Label Style="{StaticResource CaptionLabelStyle}" Text="{Binding TimingText}" />
                                            <Label Style="{StaticResource CaptionLabelStyle}" Text="{Binding PromptVersionText}" />
                                            <Label Style="{StaticResource CaptionLabelStyle}" Text="{Binding ReferencedAliasesText}" />
                                            <Label Style="{StaticResource CaptionLabelStyle}" Text="{Binding UsageText}" />
                                            <Label Text="{Binding Summary}" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>

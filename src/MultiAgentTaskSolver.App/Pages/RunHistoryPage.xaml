<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MultiAgentTaskSolver.App.Pages.RunHistoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:MultiAgentTaskSolver.App.ViewModels"
    x:DataType="viewModels:RunHistoryViewModel"
    Title="Flow &amp; History">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">
            <Label AutomationId="RunHistoryTaskTitleLabel" Text="{Binding TaskTitle}" FontAttributes="Bold" FontSize="24" />
            <Label AutomationId="RunHistoryTaskStatusLabel" Text="{Binding TaskStatusText}" FontAttributes="Bold" />
            <Label AutomationId="RunHistoryNarrativeLabel" Text="{Binding ProgressNarrative}" />
            <Label AutomationId="RunHistoryErrorLabel" Text="{Binding ErrorMessage}" TextColor="IndianRed" />

            <Label AutomationId="RunHistorySummaryHeadingLabel" Text="Progress snapshot" FontAttributes="Bold" FontSize="18" />
            <FlexLayout
                AutomationId="RunHistorySummaryMetrics"
                Direction="Row"
                Wrap="Wrap"
                BindableLayout.ItemsSource="{Binding SummaryMetrics}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:FlowSummaryMetricViewModel">
                        <Border Padding="12" Margin="0,0,12,12" MinimumWidthRequest="180">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Label}" FontSize="12" />
                                <Label Text="{Binding Value}" FontAttributes="Bold" FontSize="20" />
                                <Label Text="{Binding Detail}" FontSize="12" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>

            <Label AutomationId="RunHistoryFlowHeadingLabel" Text="Task flow" FontAttributes="Bold" FontSize="18" />
            <ScrollView Orientation="Horizontal">
                <HorizontalStackLayout
                    AutomationId="RunHistoryFlowStages"
                    Spacing="12"
                    BindableLayout.ItemsSource="{Binding FlowStages}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:TaskFlowStageViewModel">
                            <Border Padding="12" WidthRequest="230">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsCurrent}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Gray600}}" />
                                        <Setter Property="Stroke" Value="{StaticResource Primary}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsCompleted}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}" />
                                    </DataTrigger>
                                </Border.Triggers>

                                <VerticalStackLayout Spacing="6">
                                    <Label Text="{Binding Title}" FontAttributes="Bold" />
                                    <Label Text="{Binding StateText}" FontSize="12" />
                                    <Label Text="{Binding Detail}" FontSize="12" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>

            <Label AutomationId="RunHistoryTimelineHeadingLabel" Text="Run timeline" FontAttributes="Bold" FontSize="18" />
            <VerticalStackLayout
                AutomationId="RunHistoryCollectionView"
                Spacing="14"
                BindableLayout.ItemsSource="{Binding Runs}">
                <BindableLayout.EmptyView>
                    <Label Text="No runs yet." />
                </BindableLayout.EmptyView>
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:RunHistoryEntryViewModel">
                        <Border Padding="12">
                            <VerticalStackLayout Spacing="8">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="{Binding SequenceText}" FontAttributes="Bold" />
                                    <Label Text="{Binding Status}" />
                                </HorizontalStackLayout>

                                <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="18" />
                                <Label Text="{Binding KindText}" FontSize="12" />
                                <Label Text="{Binding TimingText}" FontSize="12" />
                                <Label Text="{Binding DurationText}" FontSize="12" />
                                <Label Text="{Binding ModelText}" FontSize="12" />
                                <Label Text="{Binding ReferencedAliasesText}" FontSize="12" />
                                <Label Text="{Binding StepCountText}" FontSize="12" />
                                <Label Text="{Binding Summary}" />

                                <Label Text="Steps" FontAttributes="Bold" FontSize="16" />
                                <VerticalStackLayout Spacing="10" BindableLayout.ItemsSource="{Binding Steps}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="viewModels:StepHistoryEntryViewModel">
                                            <Border Padding="10" Margin="12,0,0,0">
                                                <VerticalStackLayout Spacing="4">
                                                    <HorizontalStackLayout Spacing="8">
                                                        <Label Text="{Binding SequenceText}" FontAttributes="Bold" />
                                                        <Label Text="{Binding Status}" />
                                                    </HorizontalStackLayout>
                                                    <Label Text="{Binding Title}" FontAttributes="Bold" />
                                                    <Label Text="{Binding ModelText}" FontSize="12" />
                                                    <Label Text="{Binding ProviderText}" FontSize="12" />
                                                    <Label Text="{Binding TimingText}" FontSize="12" />
                                                    <Label Text="{Binding PromptVersionText}" FontSize="12" />
                                                    <Label Text="{Binding ReferencedAliasesText}" FontSize="12" />
                                                    <Label Text="{Binding UsageText}" FontSize="12" />
                                                    <Label Text="{Binding Summary}" />
                                                </VerticalStackLayout>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

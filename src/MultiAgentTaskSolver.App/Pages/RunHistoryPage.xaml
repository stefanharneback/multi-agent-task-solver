<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MultiAgentTaskSolver.App.Pages.RunHistoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:MultiAgentTaskSolver.App.ViewModels"
    x:DataType="viewModels:RunHistoryViewModel"
    Title="Run History">

    <VerticalStackLayout Padding="20" Spacing="14">
        <Label Text="{Binding TaskTitle}" FontAttributes="Bold" FontSize="24" />
        <Label Text="{Binding ErrorMessage}" TextColor="IndianRed" />

        <CollectionView ItemsSource="{Binding Runs}">
            <CollectionView.EmptyView>
                <Label Text="No runs yet." />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:RunEntryViewModel">
                    <Border Padding="10" Margin="0,0,0,8" StrokeThickness="1">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Title}" FontAttributes="Bold" />
                            <Label Text="{Binding Status}" />
                            <Label Text="{Binding StartedAtText}" FontSize="12" />
                            <Label Text="{Binding StepCountText}" FontSize="12" />
                            <Label Text="{Binding Summary}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>

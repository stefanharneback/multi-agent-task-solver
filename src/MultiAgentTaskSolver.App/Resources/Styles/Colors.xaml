<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MultiAgentTaskSolver.App.Resources.Styles.Colors">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Primary">#2F6C63</Color>
    <Color x:Key="PrimaryDark">#214E48</Color>
    <Color x:Key="PrimaryDarkText">#F7F3EB</Color>
    <Color x:Key="Secondary">#DCE9E3</Color>
    <Color x:Key="SecondaryDarkText">#5E7E77</Color>
    <Color x:Key="Tertiary">#9A7B4F</Color>

    <Color x:Key="White">#FCFBF8</Color>
    <Color x:Key="Black">#1F2522</Color>
    <Color x:Key="Magenta">#9A7B4F</Color>
    <Color x:Key="MidnightBlue">#214E48</Color>
    <Color x:Key="OffBlack">#171B19</Color>

    <Color x:Key="Gray100">#F5F1E8</Color>
    <Color x:Key="Gray200">#E3DACC</Color>
    <Color x:Key="Gray300">#D0C4B2</Color>
    <Color x:Key="Gray400">#AA9F92</Color>
    <Color x:Key="Gray500">#6F6A63</Color>
    <Color x:Key="Gray600">#4D4A45</Color>
    <Color x:Key="Gray900">#1F2522</Color>
    <Color x:Key="Gray950">#171B19</Color>
    <Color x:Key="Canvas">#F3EEE4</Color>
    <Color x:Key="Surface">#FBF9F4</Color>
    <Color x:Key="SurfaceRaised">#F7F2E8</Color>
    <Color x:Key="SurfaceTint">#ECE4D6</Color>
    <Color x:Key="FieldBackground">#F7F2E9</Color>
    <Color x:Key="FieldBorder">#D7CCBC</Color>
    <Color x:Key="Error">#B5544E</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
    <SolidColorBrush x:Key="CanvasBrush" Color="{StaticResource Canvas}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaised}"/>
    <SolidColorBrush x:Key="SurfaceTintBrush" Color="{StaticResource SurfaceTint}"/>
    <SolidColorBrush x:Key="FieldBackgroundBrush" Color="{StaticResource FieldBackground}"/>
    <SolidColorBrush x:Key="FieldBorderBrush" Color="{StaticResource FieldBorder}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource Error}"/>
</ResourceDictionary>
